// Prisma schema for FlorzyTech Tracker

generator client {
  provider = "prisma-client-js"
}

// Stage C: Multi-Item Sales
enum IncomeLineType {
  DEVICE
  PART
  LABOR
  OTHER
}

model IncomeLine {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  income   Income @relation(fields: [incomeId], references: [id])
  incomeId String

  type IncomeLineType

  // Associations depending on type
  device   Device? @relation(fields: [deviceId], references: [id])
  deviceId String?

  part     Part? @relation(fields: [partId], references: [id])
  partId   String?

  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])
  workOrderId String?

  // Values
  description String?
  quantity    Int?    @default(0)
  amountCents Int     @default(0)

  // Allocations from head
  allocatedPlatformFeesCents     Int @default(0)
  allocatedPaymentFeesCents      Int @default(0)
  allocatedShippingRevenueCents  Int @default(0)
  allocatedShippingCostCents     Int @default(0)
  allocatedTaxCents              Int @default(0)
}

model Income {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  date        DateTime
  type        IncomeType
  amountCents Int

  // Optional associations
  device   Device? @relation(fields: [deviceId], references: [id])
  deviceId String?

  channel   SalesChannel? @relation(fields: [channelId], references: [id])
  channelId String?

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?

  // Fees/Shipping/Tax
  platformFeesCents     Int @default(0)
  paymentFeesCents      Int @default(0)
  shippingRevenueCents  Int @default(0)
  shippingCostCents     Int @default(0)
  taxCollectedCents     Int @default(0)
  notes                 String?

  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])
  workOrderId String?

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  // Stage C: Lines
  lines IncomeLine[]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IncomeType {
  SALE
  SERVICE
  DEPOSIT
}

enum DeviceStatus {
  PURCHASED
  AWAITING_SHIPMENT
  ARRIVED
  DIAGNOSING
  WAITING_PARTS
  REPAIRING
  READY
  LISTED
  SOLD
  SHIPPED
  DELIVERED
}

enum AllocationMethod {
  PROPORTIONAL_SUBTOTAL
  EVEN
  MANUAL
}

enum WorkOrderStatus {
  OPEN
  WAITING_PARTS
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

enum WorkOrderTargetAction {
  RETURN_TO_CUSTOMER
  SELL
}

enum WorkOrderDeviceRole {
  PRIMARY
  DONOR
  ACCESSORY
}

enum WorkOrderItemType {
  PART
  LABOR
  NOTE
}

model Device {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  sku                String       @unique
  make               String
  model              String
  serial             String?
  purchasePriceCents Int          @default(0)
  purchaseDate       DateTime?
  source             String? // Freeform or future relation to Vendor
  condition          String?
  notes              String?
  status             DeviceStatus @default(PURCHASED)

  expenses Expense[]
  incomes  Income[]
  workOrderDevices WorkOrderDevice[]
  workOrderItems   WorkOrderItem[]
  incomeLines      IncomeLine[]
}

model Vendor {
  id        String   @id @default(uuid())
  name      String   @unique
  type      String? // e.g., marketplace, local_store, supplier
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  expenses Expense[]
}

model SalesChannel {
  id        String   @id @default(uuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incomes Income[]
}

model Category {
  id      String    @id @default(uuid())
  name    String    @unique
  kind    String // 'expense' or 'income' for future proofing
  active  Boolean   @default(true)
  Expense Expense[]
  Income  Income[]
}

model PaymentMethod {
  id      String    @id @default(uuid())
  name    String    @unique
  active  Boolean   @default(true)
  Expense Expense[]
}

model Expense {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  date        DateTime
  amountCents Int
  // Allocation breakdown (for split receipts)
  subtotalCents   Int      @default(0)
  taxCents        Int      @default(0)
  shippingCents   Int      @default(0)
  otherFeesCents  Int      @default(0)
  splitGroupId    String?
  allocationMethod AllocationMethod?
  notes       String?
  vendorOrderNumber String?

  // Relations
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  paymentMethodId String?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])

  deviceId String?
  device   Device? @relation(fields: [deviceId], references: [id])

  partMovements PartInventoryMovement[]
}

model Part {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  name          String
  sku           String? @unique
  partNumber    String?
  quantity      Int     @default(0)
  unitCostCents Int? // legacy; not used for average costing
  averageCostCents Int @default(0)
  notes         String?
  url           String?
  workOrderItems WorkOrderItem[]
  movements     PartInventoryMovement[]
  incomeLines   IncomeLine[]
}

model Customer {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  name       String
  email      String?
  phone      String?
  addressLine1 String?
  addressLine2 String?
  city       String?
  state      String?
  postalCode String?
  notes      String?

  incomes Income[]
  workOrders WorkOrder[]
}

model WorkOrder {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  code       String   @unique
  status     WorkOrderStatus @default(OPEN)
  targetAction WorkOrderTargetAction @default(RETURN_TO_CUSTOMER)
  notes      String?

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  devices WorkOrderDevice[]
  items   WorkOrderItem[]
  incomes Income[]
  incomeLines IncomeLine[]

  partMovements PartInventoryMovement[]
}

model WorkOrderDevice {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId String

  device   Device @relation(fields: [deviceId], references: [id])
  deviceId String

  role WorkOrderDeviceRole @default(PRIMARY)
}

model WorkOrderItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  workOrderId String

  type WorkOrderItemType

  // PART consumption or general note/labor lines
  part    Part?   @relation(fields: [partId], references: [id])
  partId  String?
  device  Device? @relation(fields: [deviceId], references: [id])
  deviceId String?

  quantity Int? @default(0) // for PART
  unitCostCentsSnapshot Int? @default(0) // captured at consumption

  // For LABOR or NOTE
  description String?
  amountCents Int? @default(0)
}



enum PartInventoryMovementType {
  RECEIPT
  CONSUME
  ADJUSTMENT
}

model PartInventoryMovement {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  archivedAt DateTime?

  type PartInventoryMovementType

  part   Part   @relation(fields: [partId], references: [id])
  partId String

  // Positive for RECEIPT/ADJUSTMENT up; negative represented by type+quantity semantics; we keep quantity positive and infer sign by type.
  quantity Int

  // Cost for this movement (per unit and total)
  unitCostCents  Int
  totalCostCents Int

  // Optional associations for traceability
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])
  workOrderId String?

  expense   Expense? @relation(fields: [expenseId], references: [id])
  expenseId String?

  notes String?
}
